# PostgreSQL
POSTGRES_DB=itam_db
POSTGRES_USER=itam_user
POSTGRES_PASSWORD=your_strong_db_password_here
DB_HOST_PORT=5432

# Redis
REDIS_PASSWORD=your_strong_redis_password_here
REDIS_HOST_PORT=6379

# JWT (BẮT BUỘC — chuỗi ngẫu nhiên ≥ 64 ký tự)
JWT_SECRET=your_very_long_and_random_jwt_secret_key_at_least_64_characters
JWT_EXPIRATION_MS=900000
JWT_REFRESH_EXPIRATION_MS=604800000

# Email (Gmail app password)
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=your-gmail@gmail.com
SPRING_MAIL_PASSWORD=your_gmail_app_password
SPRING_MAIL_FROM_NAME=Hệ thống ITAM

# Backend
# URL của frontend (dùng để set CORS và cookie domain)
APP_FRONTEND_URL=http://localhost
APP_COOKIE_SECURE=false
APP_COOKIE_SAME_SITE=Lax
APP_ADMIN_EMERGENCY_RESET_PASSWORD=

# Ports
BACKEND_HOST_PORT=8080
FRONTEND_HOST_PORT=80

# Frontend
VITE_API_BASE_URL=http://localhost:8080
VITE_API_PREFIX=/api/v1
